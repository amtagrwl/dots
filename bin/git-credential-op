#!/bin/bash
# git credential helper — GitHub PAT from 1Password via the SERVICE ACCOUNT.
# Headless-safe: no ssh-agent, no Touch ID, no login keychain. Wired as the
# FALLBACK after `gh auth git-credential` in ~/.gitconfig on both Macs:
#   git config --global --add credential.https://github.com.helper \
#     '!/Users/amtagrwl/.local/bin/git-credential-op'
# so interactive pushes keep using gh/keychain, and locked-1Password or
# ssh/launchd contexts fall through to this. Requires an HTTPS remote —
# git@github.com: SSH remotes never consult credential helpers.
# Deployed at ~/.local/bin/git-credential-op (dotbot link).
[ "${1:-}" = "get" ] || exit 0
cat >/dev/null  # drain the host/protocol description git pipes in
tok="$HOME/.config/agents/op-token"
{ [ -r "$tok" ] && command -v op >/dev/null 2>&1; } || exit 1
pat="$(OP_SERVICE_ACCOUNT_TOKEN="$(cat "$tok")" \
      op read 'op://Agents/GitHub MCP PAT/credential' 2>/dev/null)"
[ -n "$pat" ] || exit 1
printf 'username=amtagrwl\npassword=%s\n' "$pat"
