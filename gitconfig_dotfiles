# ~/.gitconfig_dotfiles - Managed by Dotbot
# Contains non-sensitive, non-1Password managed settings

[alias]
  st = status
  co = checkout
  br = branch
  ci = commit
  lg = log --oneline --graph --decorate --all
# Add other aliases or settings here
[pull]
  rebase = true # Prefer rebase over merge for git pull

# git-delta — rich, syntax-highlighted diffs (install via Brewfile: git-delta)
[core]
  pager = delta
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  side-by-side = true
  line-numbers = true
[merge]
  conflictStyle = zdiff3

